# Supabase — take from your project's API settings
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Google OAuth (Gmail). Create credentials in Google Cloud Console.
# The client ID must match NEXT_PUBLIC_GOOGLE_CLIENT_ID on the web side.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Redirect URI must match what the frontend sends (OAuthFlow.tsx builds it as
# `${origin}${basePath}/oauth/google`).
GOOGLE_REDIRECT_URI=https://your-crm.example.com/td-crm/oauth/google

# Tick intervals (ms)
POLL_INTERVAL_MS=3000
OUTBOUND_INTERVAL_MS=2000
GMAIL_POLL_INTERVAL_MS=60000

# Where to store per-integration mutable state (Baileys creds, gramjs sessions mirror, etc.)
WORKER_DATA_DIR=./.data

LOG_LEVEL=info

# HTTP port for the webhook server (Railway/Fly sets PORT automatically).
PORT=8080

# Public base URL where Meta/Google webhooks will reach the worker.
# Must be HTTPS. Example: https://td-crm-worker.up.railway.app
PUBLIC_WEBHOOK_URL=

# Fallback for the Facebook verify token (preferred source:
# oauth_apps.extra.verify_token — set it from the CRM UI).
FACEBOOK_VERIFY_TOKEN=
